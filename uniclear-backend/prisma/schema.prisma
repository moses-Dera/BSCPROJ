generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  PLATFORM_OWNER
  SUPER_ADMIN
  ADMIN
  OFFICER
  STUDENT
}

enum ClearanceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum StageStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum Tier {
  TRIAL
  STANDARD
  ENTERPRISE
}

enum StageScope {
  UNIVERSITY
  FACULTY
  DEPARTMENT
}

enum NotificationType {
  STAGE_APPROVED
  STAGE_REJECTED
  CLEARANCE_COMPLETE
  DOCUMENT_UPLOADED
  GENERAL
}

// ─────────────────────────────────────────
// UNIVERSITY (TENANT ROOT)
// ─────────────────────────────────────────

model University {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  abbreviation String
  logoUrl      String?
  primaryColor String   @default("#1B4F72")
  accentColor  String   @default("#2980B9")
  address      String
  website      String?
  contactEmail String
  webhookSecret String?  @unique
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users             User[]
  students          Student[]
  faculties         Faculty[]
  stages            ClearanceStage[]
  documentTypes     DocumentType[]
  clearanceRequests ClearanceRequest[]
  campaigns         ClearanceCampaign[]
  notifications     Notification[]
  sessions          AcademicSession[]
  branding          UniversityBranding?
  contract          ContractPlan?
  officerStamps     OfficerStamp[]

  @@index([slug])
}

// ─────────────────────────────────────────
// UNIVERSITY BRANDING
// ─────────────────────────────────────────

model UniversityBranding {
  universityId   String     @id
  faviconUrl     String?
  bannerMessage  String?
  footerText     String?
  loginBgUrl     String?
  certificateTemplateUrl String?
  certificateTemplateKey String?
  certificateCoordinates Json?
  updatedAt      DateTime   @updatedAt

  university     University @relation(fields: [universityId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// CONTRACT / SUBSCRIPTION
// ─────────────────────────────────────────

model ContractPlan {
  id           String     @id @default(uuid())
  universityId String     @unique
  tier         Tier       @default(TRIAL)
  contractRef  String?
  startedAt    DateTime   @default(now())
  expiresAt    DateTime?
  notes        String?
  isActive     Boolean    @default(true)
  updatedAt    DateTime   @updatedAt

  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// USERS
// ─────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  universityId   String?
  email          String    @unique
  passwordHash   String
  role           Role
  isActive       Boolean   @default(true)
  passwordSetAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  university     University?      @relation(fields: [universityId], references: [id], onDelete: Cascade)
  officer        Officer?
  stageApprovals StageApproval[]
  notifications  Notification[]
  auditLogs      AuditLog[]       @relation("ActorLogs")
  refreshTokens  RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  officerStamps  OfficerStamp[]

  @@index([universityId])
  @@index([email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ─────────────────────────────────────────
// FACULTY & DEPARTMENT
// ─────────────────────────────────────────

model Faculty {
  id           String       @id @default(uuid())
  universityId String
  name         String
  createdAt    DateTime     @default(now())

  university          University                @relation(fields: [universityId], references: [id], onDelete: Cascade)
  departments         Department[]
  students            Student[]
  officerAssignments  StageOfficerAssignment[]
  docRequirements     StageDocumentRequirement[]
  targetedCampaigns   ClearanceCampaign[]

  @@index([universityId])
}

model Department {
  id        String    @id @default(uuid())
  facultyId String
  name      String
  createdAt DateTime  @default(now())

  faculty             Faculty                   @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  students            Student[]
  officerAssignments  StageOfficerAssignment[]
  docRequirements     StageDocumentRequirement[]
  targetedCampaigns   ClearanceCampaign[]

  @@index([facultyId])
}

// ─────────────────────────────────────────
// STUDENT
// ─────────────────────────────────────────

model Student {
  id             String   @id @default(uuid())
  universityId   String
  userId         String?   @unique
  jambRegNo      String
  matricNo       String?
  firstName      String
  lastName       String
  facultyId      String?
  departmentId   String?
  level          String?
  phone          String?
  entrySessionId String?
  entryYear      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  university        University         @relation(fields: [universityId], references: [id], onDelete: Cascade)
  faculty           Faculty?           @relation(fields: [facultyId], references: [id])
  department        Department?        @relation(fields: [departmentId], references: [id])
  entrySession      AcademicSession?   @relation(fields: [entrySessionId], references: [id])
  clearanceRequests ClearanceRequest[]
  documents         Document[]

  @@unique([universityId, jambRegNo])
  @@unique([universityId, matricNo])
  @@index([universityId])
}

// ─────────────────────────────────────────
// OFFICER
// ─────────────────────────────────────────

model Officer {
  id           String          @id @default(uuid())
  universityId String
  userId       String          @unique
  firstName    String
  lastName     String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stageAssignments  StageOfficerAssignment[]
  approvals         StageApproval[]
  stamps            OfficerStamp[]

  @@index([universityId])
}

// ─────────────────────────────────────────
// CLEARANCE CAMPAIGNS (V2)
// ─────────────────────────────────────────

model ClearanceCampaign {
  id                 String      @id @default(uuid())
  universityId       String
  name               String
  description        String?
  targetFacultyId    String?
  targetDepartmentId String?
  targetLevel        String?     // e.g., '100', '400', 'FINAL_YEAR'
  whitelistEnabled   Boolean     @default(false)
  whitelist          String[]    @default([]) // Array of matric numbers
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  university         University         @relation(fields: [universityId], references: [id], onDelete: Cascade)
  targetFaculty      Faculty?           @relation(fields: [targetFacultyId], references: [id])
  targetDepartment   Department?        @relation(fields: [targetDepartmentId], references: [id])
  stages             ClearanceStage[]
  clearanceRequests  ClearanceRequest[]

  @@index([universityId])
}

// ─────────────────────────────────────────
// CLEARANCE STAGES
// ─────────────────────────────────────────

model ClearanceStage {
  id           String      @id @default(uuid())
  universityId String
  campaignId   String
  name         String
  description  String?
  orderIndex   Int
  scope        StageScope  @default(UNIVERSITY)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  university            University                  @relation(fields: [universityId], references: [id], onDelete: Cascade)
  campaign              ClearanceCampaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  officerAssignments    StageOfficerAssignment[]
  stageApprovals        StageApproval[]
  documentRequirements  StageDocumentRequirement[]

  @@index([universityId, campaignId, orderIndex])
}

// ─────────────────────────────────────────
// STAGE OFFICER ASSIGNMENT
// ─────────────────────────────────────────

model StageOfficerAssignment {
  id           String   @id @default(uuid())
  universityId String
  stageId      String
  officerId    String
  facultyId    String?
  departmentId String?
  sessionId    String?
  createdAt    DateTime @default(now())

  stage        ClearanceStage  @relation(fields: [stageId], references: [id], onDelete: Cascade)
  officer      Officer         @relation(fields: [officerId], references: [id], onDelete: Cascade)
  faculty      Faculty?        @relation(fields: [facultyId], references: [id])
  department   Department?     @relation(fields: [departmentId], references: [id])
  session      AcademicSession? @relation(fields: [sessionId], references: [id])

  @@unique([stageId, officerId, facultyId, departmentId, sessionId])
  @@index([universityId])
  @@index([stageId])
  @@index([officerId])
}

// ─────────────────────────────────────────
// DOCUMENT TYPES
// ─────────────────────────────────────────

model DocumentType {
  id             String    @id @default(uuid())
  universityId   String
  name           String
  description    String?
  isRequired     Boolean   @default(true)
  allowedFormats String[]  @default(["pdf", "jpg", "png"])
  maxFileSizeMB  Int       @default(5)
  order          Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  university         University                 @relation(fields: [universityId], references: [id], onDelete: Cascade)
  stageRequirements  StageDocumentRequirement[]
  documents          Document[]

  @@index([universityId])
}

model StageDocumentRequirement {
  id             String   @id @default(uuid())
  universityId   String
  stageId        String
  documentTypeId String
  isRequired     Boolean  @default(true)
  facultyId      String?
  departmentId   String?
  sessionId      String?
  level          String?

  stage          ClearanceStage  @relation(fields: [stageId], references: [id], onDelete: Cascade)
  documentType   DocumentType    @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)
  faculty        Faculty?        @relation(fields: [facultyId], references: [id])
  department     Department?     @relation(fields: [departmentId], references: [id])
  session        AcademicSession? @relation(fields: [sessionId], references: [id])

  @@unique([stageId, documentTypeId, facultyId, departmentId, sessionId, level])
  @@index([universityId])
}

// ─────────────────────────────────────────
// ACADEMIC SESSION
// ─────────────────────────────────────────

model AcademicSession {
  id           String             @id @default(uuid())
  universityId String
  name         String
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  university          University                @relation(fields: [universityId], references: [id], onDelete: Cascade)
  clearanceRequests   ClearanceRequest[]
  entryStudents       Student[]
  officerAssignments  StageOfficerAssignment[]
  docRequirements     StageDocumentRequirement[]

  @@index([universityId])
}

// ─────────────────────────────────────────
// CLEARANCE REQUEST
// ─────────────────────────────────────────

model ClearanceRequest {
  id             String          @id @default(uuid())
  studentId      String
  universityId   String
  campaignId     String
  sessionId      String
  status         ClearanceStatus @default(PENDING)
  stageStatus    StageStatus     @default(PENDING)
  currentStageId String?
  completedAt    DateTime?
  updatedAt      DateTime        @updatedAt
  createdAt      DateTime        @default(now())

  university     University      @relation(fields: [universityId], references: [id], onDelete: Cascade)
  campaign       ClearanceCampaign @relation(fields: [campaignId], references: [id])
  student        Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session        AcademicSession @relation(fields: [sessionId], references: [id])
  stageApprovals StageApproval[]
  documents      Document[]

  @@unique([studentId, sessionId, campaignId])
  @@index([universityId])
  @@index([studentId])
}

// ─────────────────────────────────────────
// STAGE APPROVAL (IMMUTABLE AUDIT RECORD)
// ─────────────────────────────────────────

model StageApproval {
  id           String      @id @default(uuid())
  universityId String
  requestId    String
  stageId      String
  officerId    String
  status       StageStatus
  remarks       String?
  attachmentUrl String?
  attachmentKey String?
  decidedAt     DateTime    @default(now())
  ipAddress     String?

  request      ClearanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  stage        ClearanceStage   @relation(fields: [stageId], references: [id])
  officer      User             @relation(fields: [officerId], references: [id], map: "StageApproval_user_fkey")
  officerRef   Officer          @relation(fields: [officerId], references: [userId], map: "StageApproval_officer_fkey")

  @@index([universityId])
  @@index([requestId])
}

// ─────────────────────────────────────────
// OFFICER STAMPS (DIGITAL SIGNATURES/STAMPS)
// ─────────────────────────────────────────

model OfficerStamp {
  id           String   @id @default(uuid())
  universityId String
  officerId    String
  name         String
  imageUrl     String
  imageKey     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  officer      User       @relation(fields: [officerId], references: [id], onDelete: Cascade, map: "OfficerStamp_user_fkey")
  officerRef   Officer    @relation(fields: [officerId], references: [userId], onDelete: Cascade, map: "OfficerStamp_officer_fkey")

  @@index([universityId])
  @@index([officerId])
}

// ─────────────────────────────────────────
// DOCUMENTS (UPLOADED FILES)
// ─────────────────────────────────────────

model Document {
  id             String   @id @default(uuid())
  universityId   String
  studentId      String
  requestId      String
  documentTypeId String
  fileName       String
  fileUrl        String
  fileKey        String
  fileSizeMB     Float
  mimeType       String
  uploadedAt     DateTime @default(now())

  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  request        ClearanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  documentType   DocumentType     @relation(fields: [documentTypeId], references: [id])

  @@index([universityId])
  @@index([requestId])
  @@index([studentId])
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id           String           @id @default(uuid())
  universityId String
  userId       String
  type         NotificationType
  title        String
  message      String
  isRead       Boolean          @default(false)
  metadata     Json?
  createdAt    DateTime         @default(now())

  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([universityId])
  @@index([userId])
}

// ─────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  universityId String
  actorId      String
  action       String
  targetId     String?
  targetType   String?
  metadata     Json?
  ipAddress    String?
  createdAt    DateTime @default(now())

  actor        User     @relation("ActorLogs", fields: [actorId], references: [id])

  @@index([universityId])
  @@index([actorId])
}

// ─────────────────────────────────────────
// PASSWORD RESET TOKENS
// ─────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
