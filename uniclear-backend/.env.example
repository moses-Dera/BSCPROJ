# Database
DATABASE_URL="postgresql://user:password@localhost:5432/uniclear"

# JWT
JWT_ACCESS_SECRET="your-access-secret-min-32-chars-here"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars-here"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV="development"
CLIENT_URL="http://localhost:3000"

# Storage
STORAGE_PROVIDER="local"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Cache
CACHE_PROVIDER="memory"
REDIS_URL=""

# Email
EMAIL_PROVIDER="mailpit"        # mailpit | resend
EMAIL_FROM="UniClear <noreply@uniclear.ng>"
APP_URL="http://localhost:3000"

# Mailpit (local dev — run via docker-compose)
SMTP_HOST="localhost"
SMTP_PORT=1025

# Resend (deployed / teammates)
RESEND_API_KEY=""
